DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/scoresheet
# Must match NEXTAUTH_SECRET from frontend. Empty = dev bypass mode.
AUTH_SECRET=
MLB_API_BASE_URL=https://statsapi.mlb.com/api/v1
SCORESHEET_BASE_URL=https://www.scoresheet.com
CORS_ORIGINS=http://localhost:3000
INTERNAL_API_KEY=

# League seeding configuration
SEED_LEAGUE_NAME=AL Catfish Hunter
SEED_LEAGUE_SEASON=2026

# User seeding (format: email:team_id:role,email:team_id:role,...)
# Add your Google account email here to allow login
SEED_USERS=user@example.com:1:owner

# Default IDs for backward compatibility
DEFAULT_TEAM_ID=1
DEFAULT_LEAGUE_ID=1
